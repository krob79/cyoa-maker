cc8","newline":false,"hasEvents":false,"elements":[{"uuid":"afe8b7f1-f88f-4eb4-ab4e-957799dfd002","title":"user_drink_=_1","parent":"74a0a0a9-2a7b-4108-97b4-1ba26be67623","type":"event","value":"user_drink_=_1","elements":[]}]},{"uuid":"5ed642b5-e489-4e90-8e8f-9394ee9dd8ef","title":"Beer. Now.||a941cc42-c96b-4565-bbf8-c94b0087bcc8","parent":"8c135403-f57e-4a06-8065-f5b8733e168a","type":"choice","value":"Beer. Now.||a941cc42-c96b-4565-bbf8-c94b0087bcc8","newline":false,"hasEvents":false,"elements":[{"uuid":"4f761b1e-2cfb-4bbd-8d54-f20eb18929a5","title":"user_drink_=_2","parent":"5ed642b5-e489-4e90-8e8f-9394ee9dd8ef","type":"event","value":"user_drink_=_2","elements":[]}]},{"uuid":"84b7863b-2a97-4585-8214-05fc5dc5e5de","title":"Give me a shot of the strongest thing you have.||a941cc42-c96b-4565-bbf8-c94b0087bcc8","parent":"8c135403-f57e-4a06-8065-f5b8733e168a","type":"choice","value":"Give me a shot of the strongest thing you have.||a941cc42-c96b-4565-bbf8-c94b0087bcc8","newline":false,"hasEvents":false,"elements":[{"uuid":"aa688457-d996-4a79-8b1a-1294e13ed98c","title":"user_drink_=_3","parent":"84b7863b-2a97-4585-8214-05fc5dc5e5de","type":"event","value":"user_drink_=_3","elements":[]}]}]},{"parent":"b69d00be-744f-465c-bb90-c2a3a938ce20","title":"Roccos - Order Drink","uuid":"a941cc42-c96b-4565-bbf8-c94b0087bcc8","type":"page","value":"Roccos - Order Drink","elements":[{"uuid":"659fd45d-613b-4795-9a41-bc2f0217bdd2","title":"The bartender starts filling a semi-clean mug with semi-cold beer.","parent":"a941cc42-c96b-4565-bbf8-c94b0087bcc8","type":"text","value":"The bartender starts filling a semi-clean mug with semi-cold beer. A short, mocking laugh comes from a few feet to your right and the bartender shoots a worried look in that direction. You could have sworn he just mumbled, \"aww, shit\" under his breath.","newline":false,"elements":[]},{"uuid":"74a285e9-3bd8-469d-b727-7307b0c64668","title":"A short, mocking laugh comes from a few feet to your right. &quot;Beer, please?!? Such NICE manners!&quot;","parent":"a941cc42-c96b-4565-bbf8-c94b0087bcc8","type":"text","value":"\"Beer, please?!? Such NICE manners!\"","newline":true,"elements":[]},{"uuid":"c94a1515-e966-485e-bec1-5fbdf49f366a","title":"scary_larry1.png","parent":"a941cc42-c96b-4565-bbf8-c94b0087bcc8","type":"image","value":"scary_larry1.png","elements":[]},{"uuid":"b7ec47f6-e740-42e6-9f5f-fc56550299d5","title":"The patron sitting next to you gets shoved out of the way, revealing a rather intimidating man on the other side.","parent":"a941cc42-c96b-4565-bbf8-c94b0087bcc8","type":"text","value":"The patron sitting next to you gets shoved out of the way, revealing a rather intimidating man on the other side.","newline":true,"elements":[]},{"uuid":"27066ce9-8b9c-47ce-b3f2-6eb6cba2d037","title":"&quot;This is obviously your first time here at Rocco&#x27;s. I sure as hell don&#x27;t remember inviting you. How did you find this place?&quot;","parent":"a941cc42-c96b-4565-bbf8-c94b0087bcc8","type":"text","value":"\"This is obviously your first time here at Rocco's. I sure as hell don't remember inviting you. How did you find this place?\"","newline":true,"elements":[]},{"uuid":"8dbb5c8c-1508-4541-bbf4-28ad073c933a","title":"&quot;Just passing through. Having a beer and will be on my way.&quot;||1ef5b17b-d67d-46b7-8456-48410b0b0177","parent":"a941cc42-c96b-4565-bbf8-c94b0087bcc8","type":"choice","value":"Just passing through. Having a beer and will be on my way.||1ef5b17b-d67d-46b7-8456-48410b0b0177","newline":false,"hasEvents":false,"elements":[{"uuid":"48ebd3cf-f3da-418b-8fc3-7aa465f1a72d","title":"user_larryreply_=_1","parent":"8dbb5c8c-1508-4541-bbf4-28ad073c933a","type":"event","value":"user_larryreply_=_1","elements":[]}]},{"uuid":"d443a8b6-ca2b-4628-8309-54c90ca9d328","title":"Who gives a shit? I&#x27;m having a drink.||1ef5b17b-d67d-46b7-8456-48410b0b0177","parent":"a941cc42-c96b-4565-bbf8-c94b0087bcc8","type":"choice","value":"I sure as hell don't remember how it's any of your business.||1ef5b17b-d67d-46b7-8456-48410b0b0177","newline":false,"hasEvents":false,"elements":[{"uuid":"cd637559-925d-4e6c-8e52-bf2b2737ea91","title":"user_larryreply_=_2","parent":"d443a8b6-ca2b-4628-8309-54c90ca9d328","type":"event","value":"user_larryreply_=_2","elements":[]}]}]},{"parent":"b69d00be-744f-465c-bb90-c2a3a938ce20","title":"Roccos - Reply","uuid":"1ef5b17b-d67d-46b7-8456-48410b0b0177","type":"page","value":"Roccos - Reply","elements":[{"uuid":"3ba4c2ee-5165-4ff5-b517-c3c560cd2181","title":"The man quietly glares at you for a long 5 seconds.","parent":"1ef5b17b-d67d-46b7-8456-48410b0b0177","type":"text","value":"The man quietly glares at you for a long 5 seconds.","newline":false,"elements":[{"uuid":"881abad6-8015-450f-9a5b-7f316a2fb935","title":"larryreply=1","parent":"3ba4c2ee-5165-4ff5-b517-c3c560cd2181","type":"condition","value":"larryreply=1","elements":[]}]},{"uuid":"a7eef3d4-888e-42b6-9019-f9276edcc093","title":"&quot;That wasn&#x27;t what I asked. I said...how did you find this place?&quot;","parent":"1ef5b17b-d67d-46b7-8456-48410b0b0177","type":"text","value":"\"That wasn't what I asked. I said...how did you find this place?\"","newline":true,"elements":[{"uuid":"760737fc-15c7-4145-8f94-00bdf1eb91fc","title":"larryreply=1","parent":"a7eef3d4-888e-42b6-9019-f9276edcc093","type":"condition","value":"larryreply=1","elements":[]}]},{"uuid":"2de2d910-bc99-4717-b686-c61766b38e87","title":"For just a instant, the man looks surprised, but then busts out laughing.","parent":"1ef5b17b-d67d-46b7-8456-48410b0b0177","type":"text","value":"For just a instant, the man looks surprised, but then busts out laughing.","newline":false,"elements":[{"uuid":"901a7394-0c3e-40f2-94be-f04544d8c325","title":"larryreply=2","parent":"2de2d910-bc99-4717-b686-c61766b38e87","type":"condition","value":"larryreply=2","elements":[]}]},{"uuid":"749382da-c4f8-4e55-8f05-820edfcc17b9","title":"scary_larry0.png","parent":"1ef5b17b-d67d-46b7-8456-48410b0b0177","type":"image","value":"scary_larry0.png","elements":[{"uuid":"c3b07de2-83b2-47c8-9f6a-97019f4e3d48","title":"larryreply=2","parent":"749382da-c4f8-4e55-8f05-820edfcc17b9","type":"condition","value":"larryreply=2","elements":[]}]},{"uuid":"9f648ac9-afe4-4b68-9a88-a7cc3dbbaeab","title":"scary_larry2.png","parent":"1ef5b17b-d67d-46b7-8456-48410b0b0177","type":"image","value":"scary_larry2.png","elements":[{"uuid":"2b6a7619-4d8c-4d1e-8752-2bf56226e9f6","title":"larryreply=1","parent":"9f648ac9-afe4-4b68-9a88-a7cc3dbbaeab","type":"condition","value":"larryreply=1","elements":[]}]},{"uuid":"eeec5e7b-25cd-400e-b895-95edcb260a83","title":"&quot;Wow! Such balls to say that to me! I miss seeing new faces like yours! No fear of what&#x27;s coming next! No fear of approaching death! That&#x27;s the price of fame, I guess. All I see in people&#x27;s eyes these days are fear. SO...you&#x27;re not afraid, because you have a death wish...or you&#x27;re way too stupid to know better. Which are you?&quot;","parent":"1ef5b17b-d67d-46b7-8456-48410b0b0177","type":"text","value":"\"Wow! Such balls to say that to me! I miss seeing new faces like yours! No fear of what's coming next! No fear of approaching death! That's the price of fame, I guess. All I see in people's eyes these days are fear. SO...you're not afraid, because you have a death wish...or you're way too stupid to know better. Which are you?\"","newline":true,"elements":[{"uuid":"0d31bb90-193b-45df-82d7-dedaeb261edd","title":"larryreply=2","parent":"eeec5e7b-25cd-400e-b895-95edcb260a83","type":"condition","value":"larryreply=2","elements":[]}]}]},{"parent":"b69d00be-744f-465c-bb90-c2a3a938ce20","title":"Test Page For Choice Events","uuid":"8f1b2362-7da6-42ee-ad2d-c6ba1588fdac","type":"page","value":"Test Page For Choice Events","elements":[{"uuid":"db335c1f-3002-4781-adcd-6bd0f22abbee","title":"Link with New Page||6dfc895c-d751-48cd-b354-d96a28c049b9","parent":"8f1b2362-7da6-42ee-ad2d-c6ba1588fdac","type":"choice","value":"Link with New 