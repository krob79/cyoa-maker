                    {
                        "uuid": "60f3d868-5ec5-4d5c-b4f9-9828281cf5da",
                        "type": "text",
                        "value": "While they were there, they decided to do some snorkeling...",
                        "html": "<p class=\"pageText\">While they were there, they decided to do some snorkeling...</p>",
