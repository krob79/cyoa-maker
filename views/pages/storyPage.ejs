<div class="container mt-4">
    <div class="row">
        <div class="col-md-4">
            <div class="maincontent">
                <h1>Create New Story Element</h1>
                <p>Choose a story element to add:</p>
                <button type="button" class="btn btn-secondary newElement" data-toggle="modal" data-request="POST"
                    data-elementtype="text" data-elementuuid="<%=pageData.uuid %>" data-elementvalue=""
                    data-target="#textUpdateModal">New
                    Text</button>
                <button type="button" class="btn btn-secondary newElement" data-toggle="modal" data-request="POST"
                    data-elementtype="image" data-elementuuid="<%=pageData.uuid %>" data-elementvalue=""
                    data-target="#imageUpdateModal">New Image</button>
                <button type="button" class="btn btn-secondary newElement" data-toggle="modal" data-request="POST"
                    data-elementtype="choice" data-elementuuid="<%=pageData.uuid %>" data-elementvalue=""
                    data-target="#choiceUpdateModal">New Choice</button>

                <div class="feedback-status">
                    <% if(locals.errors){%>
                        <div class="alert alert-danger">
                            <ul>
                                <% errors.forEach(function (error){%>
                                    <li>
                                        <%= error.msg %>
                                    </li>
                                    <%})%>
                            </ul>
                        </div>
                        <%}else if(locals.successMessage) {%>
                            <div class="alert alert-success">
                                <%= successMessage %>
                            </div>
                            <%}%>
                </div>
            </div>
        </div>
        <aside class="col-md-8">
            <div class="maincontent feedback">
                <h1>
                    <%= pageData.title %>
                </h1>

                <div class="feedback-items">
                    <% pageData.elements.forEach(function (item) {%>
                        <%- include('partials/elementPartial', {item: item}); %>
                            <%})%>

                </div>
            </div>
        </aside>
    </div>
    <div class="modal fade elementModal" id="textUpdateModal" tabindex="-1" aria-labelledby="textUpdateLabel"
        aria-hidden="true">
        <div class="modal-dialog modal-lg">
            <%- include('partials/formElementTextModal', {uuid:pageData.uuid}); %>
        </div>
    </div>
    <div class="modal fade elementModal" id="imageUpdateModal" tabindex="-1" aria-labelledby="elementUpdateLabel"
        aria-hidden="true">
        <div class="modal-dialog modal-lg">
            <%- include('partials/formElementImageModal', {uuid:pageData.uuid}); %>
        </div>
    </div>
    <div class="modal fade elementModal" id="choiceUpdateModal" tabindex="-1" aria-labelledby="textUpdateLabel"
        aria-hidden="true">
        <div class="modal-dialog modal-lg">
            <%- include('partials/formElementChoiceModal', {uuid:pageData.uuid}); %>
        </div>
    </div>


</div>