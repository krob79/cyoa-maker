<!-- If type choice, split the text value and isolate the UUID destination -->
<% const parts=String(item.value||'').split('||'); %>
    <% const label=parts[0] || '' ; const dest=parts[1] || '' ; %>
        <% if (dest) { %>
            <% if (dest=="Event" ){ %>
                <strong><a class="pageLink userevent" data-uuid="<%= item.uuid %>" href="javascript:void(0)">
                        <%= label %>
                    </a></strong>
                <%}else {%>

                    <% if (allPageUUIDs.includes(dest)){%>
                        <strong><a class="pageLink choiceLink" data-uuid="<%= item.uuid %>"
                                href="/page/<%= dest %>/edit">
                                <%= label %>
                            </a></strong>
                        <%}else{%>
                            <a href="#"><svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 14 14"
                                    id="Broken-Link-1--Streamline-Flex" height="14" width="14">
