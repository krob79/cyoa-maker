<div class="modal-content">
    <div class="modal-header">
        <h5 class="modal-title element-modal-title" id="modaleventLabel">Form Title</h5>
    </div>
    <div class="modal-body">

        <form id="eventFormModal" class="row g-3 mb-3 was-validated" novalidate>
            <div class="container">
                <input type="hidden" name="hiddeneventuuid" id="hiddeneventuuid" value="<%=uuid %>">
                <input type="hidden" name="modalEventType" id="modalEventType">
                <input type="hidden" name="section" value="elements">
                <input type="hidden" id="comparisonModal" name="comparisonModal" value="">
                <input type="hidden" id="eventRequest" name="eventRequest" value="">
                <div class="row">
                    <div class="col">
                        <span id="eventMessage"></span>
                    </div>
                </div>
                <div class="row justify-content-center">
                    <div class="col">
                        <div class="input-group">
                            <span class="input-group-text" id="basic-addon3">Property Name:</span>
                            <input type="text" class="form-control" name="eventProperty" id="eventProperty"
                                aria-describedby="basic-addon3 basic-addon4">
                        </div>
                        <div class="valid-feedback">
                            Looks good!
                        </div>
                    </div>
                </div>
                <div class="row justify-content-center">
                    <div class="col">
                        <div class="input-group">
                            <label class="input-group-text" for="inputGroupSelect01">Method of Change:</label>
                            <select class="form-select" id="eventOperator" name="eventOperator"
                                onchange="changeoperator()">
                                <option value="-">decrease value by</option>
                                <option value="=">set value equal to</option>
                                <option value="+">increase value by</option>
                            </select>
                        </div>
                    </div>
                    <div class="col">
                        <div class="input-group">
                            <span class="input-group-text" id="basic-addon4">Value:</span>
                            <input type="text" class="form-control" name="eventAmount" id="eventAmount"
                                aria-describedby="basic-addon3 basic-addon4">
                        </div>
                    </div>
                </div>
                <div class="row">
                    <div class="col">
                        <input type="checkbox" id="eventDisplayEvent" name="eventDisplayEvent">
                        <label for="eventDisplayEvent" class="form-label">Display Alert On Page When Event
                            Triggers</label>
                    </div>
                    <div class="col-sm-12">
                        <a id="modaleventConditions" href="">Review Conditions For This Event ></a>
                        <div class="modal-footer">
                            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                            <button class="btn btn-primary" type="submit">Update</button>
                        </div>
                    </div>
                </div>
            </div>
        </form>


    </div>



</div>

</div>
<%- include('formElementValidation', {}); %>
    <script>

        function changeoperator(display = null) {

            let dropdown = document.getElementById('eventOperator');
            let hiddeneventuuid = document.getElementById("hiddeneventuuid");
            let comparisonModal = document.getElementById("comparisonModal");

            if (display) {
                comparisonModal.value = display;
            } else {
                comparisonModal.value = dropdown.value
            }

            console.log("calling changeoperator() ", dropdown.value);
            // console.log(choiceDropdown);
            // if (destination.value == "Choose Page") {
            //   document.getElementById("choiceElementSubmit").disabled = true;
            // } else {
            //   document.getElementById("choiceElementSubmit").disabled = false;
            // }
        }

    </script>