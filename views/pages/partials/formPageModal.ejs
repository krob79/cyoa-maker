<div class="modal-content">
    <div class="modal-header">
        <h5 class="modal-title element-modal-title" id="modalpageLabel">Form Title</h5>
    </div>
    <div class="modal-body">
        <form id="pageFormModal" class="row g-3 was-validated" novalidate>
            <input type="hidden" id="hiddenpageuuid" name="uuid" value="<%=uuid %>">
            <input type="hidden" id="section" name="section" value="elements">
            <input type="hidden" id="pagerequest" name="pagerequest" value="">
            <div class="col-md-12">
                <label for="value" class="form-label">Page Title:</label>
                <textarea type="text" class="form-control" id="modalpageInput" name="modalpageInput"
                    placeholder="Enter a title for the page." required></textarea>
                <div class="valid-feedback">
                    Looks good!
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button class="btn btn-primary" type="submit">Update</button>
            </div>
        </form>
    </div>

</div>
