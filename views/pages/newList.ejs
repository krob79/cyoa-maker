<div class="container mt-4">
    <div class="row">
        <div class="col-md-4">
            <div class="maincontent">
                <% if(pageData.type=="story" ) {%>
                    <button type="button" class="btn btn-secondary newElement" data-bs-toggle="modal"
                        data-bs-request="POST" data-bs-elementtype="page" data-bs-elementuuid="<%=story.uuid %>"
                        data-bs-elementvalue="" data-bs-target="#pageUpdateModal">+<svg
                            xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor"
                            class="bi bi-file-earmark" viewBox="0 0 16 16">
                            <path
                                d="M14 4.5V14a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V2a2 2 0 0 1 2-2h5.5zm-3 0A1.5 1.5 0 0 1 9.5 3V1H4a1 1 0 0 0-1 1v12a1 1 0 0 0 1 1h8a1 1 0 0 0 1-1V4.5z" />
                        </svg></button>
                    <hr>
                    <%}%>
                        <% if(pageData.type=="page" ) {%>
                            <button type="button" class="btn btn-secondary newElement" data-bs-toggle="modal"
                                data-bs-request="POST" data-bs-elementtype="text"
                                data-bs-elementuuid="<%=pageData.uuid %>" data-bs-elementvalue=""
                                data-bs-target="#textUpdateModal">+
                                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor"
                                    class="bi bi-type" viewBox="0 0 16 16">
                                    <path
                                        d="m2.244 13.081.943-2.803H6.66l.944 2.803H8.86L5.54 3.75H4.322L1 13.081zm2.7-7.923L6.34 9.314H3.51l1.4-4.156zm9.146 7.027h.035v.896h1.128V8.125c0-1.51-1.114-2.345-2.646-2.345-1.736 0-2.59.916-2.666 2.174h1.108c.068-.718.595-1.19 1.517-1.19.971 0 1.518.52 1.518 1.464v.731H12.19c-1.647.007-2.522.8-2.522 2.058 0 1.319.957 2.18 2.345 2.18 1.06 0 1.716-.43 2.078-1.011zm-1.763.035c-.752 0-1.456-.397-1.456-1.244 0-.65.424-1.115 1.408-1.115h1.805v.834c0 .896-.752 1.525-1.757 1.525" />
                                </svg>
                            </button>
                            <button type="button" class="btn btn-secondary newElement" data-bs-toggle="modal"
                                data-bs-request="POST" data-bs-elementtype="image"
                                data-bs-elementuuid="<%=pageData.uuid %>" data-bs-elementvalue=""
                                data-bs-target="#imageUpdateModal">+<svg xmlns="http://www.w3.org/2000/svg" width="16"
                                    height="16" fill="currentColor" class="bi bi-image" viewBox="0 0 16 16">
                                    <path d="M6.002 5.5a1.5 1.5 0 1 1-3 0 1.5 1.5 0 0 1 3 0" />
                                    <path
                                        d="M2.002 1a2 2 0 0 0-2 2v10a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V3a2 2 0 0 0-2-2zm12 1a1 1 0 0 1 1 1v6.5l-3.777-1.947a.5.5 0 0 0-.577.093l-3.71 3.71-2.66-1.772a.5.5 0 0 0-.63.062L1.002 12V3a1 1 0 0 1 1-1z" />
                                </svg>
                            </button>
                            <button type="button" class="btn btn-secondary newElement" data-bs-toggle="modal"
                                data-bs-request="POST" data-bs-elementtype="choice" data-bs-storyuuid="<%=story.uuid%>"
                                data-bs-elementuuid="<%=pageData.uuid %>" data-bs-elementvalue=""
                                data-bs-target="#choiceUpdateModal">+<svg xmlns="http://www.w3.org/2000/svg" width="16"
                                    height="16" fill="currentColor" class="bi bi-link-45deg" viewBox="0 0 16 16">
                                    <path
                                        d="M4.715 6.542 3.343 7.914a3 3 0 1 0 4.243 4.243l1.828-1.829A3 3 0 0 0 8.586 5.5L8 6.086a1 1 0 0 0-.154.199 2 2 0 0 1 .861 3.337L6.88 11.45a2 2 0 1 1-2.83-2.83l.793-.792a4 4 0 0 1-.128-1.287z" />
                                    <path
                                        d="M6.586 4.672A3 3 0 0 0 7.414 9.5l.775-.776a2 2 0 0 1-.896-3.346L9.12 3.55a2 2 0 1 1 2.83 2.83l-.793.792c.112.42.155.855.128 1.287l1.372-1.372a3 3 0 1 0-4.243-4.243z" />
                                </svg></button>
                            <button type="button" class="btn btn-secondary newElement" data-bs-toggle="modal"
                                data-bs-request="POST" data-bs-elementtype="image"
                                data-bs-elementuuid="<%=pageData.uuid %>" data-bs-elementvalue=""
                                data-bs-target="#aiimageUpdateModal">+<svg xmlns="http://www.w3.org/2000/svg" width="16"
                                    height="16" fill="currentColor" class="bi bi-image" viewBox="0 0 16 16">
                                    <path d="M6.002 5.5a1.5 1.5 0 1 1-3 0 1.5 1.5 0 0 1 3 0" />
                                    <path
                                        d="M2.002 1a2 2 0 0 0-2 2v10a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V3a2 2 0 0 0-2-2zm12 1a1 1 0 0 1 1 1v6.5l-3.777-1.947a.5.5 0 0 0-.577.093l-3.71 3.71-2.66-1.772a.5.5 0 0 0-.63.062L1.002 12V3a1 1 0 0 1 1-1z" />
                                </svg>
                                <svg width="16" height="16" viewBox="0 0 16 16" xmlns="http://www.w3.org/2000/svg"
                                    fill="currentColor">
                                    <path
                                        d="M 5.398 10.807 C 5.574 10.931 5.785 10.998 6 10.997 C 6.216 10.998 6.427 10.93 6.602 10.804 C 6.78 10.674 6.915 10.494 6.989 10.286 L 7.436 8.913 C 7.551 8.569 7.744 8.256 8 7.999 C 8.257 7.743 8.569 7.549 8.913 7.434 L 10.304 6.983 C 10.456 6.929 10.594 6.84 10.706 6.724 C 10.817 6.608 10.901 6.467 10.949 6.313 C 10.998 6.159 11.01 5.996 10.985 5.837 C 10.96 5.677 10.898 5.526 10.804 5.394 C 10.67 5.208 10.479 5.071 10.26 5.003 L 8.885 4.556 C 8.541 4.442 8.228 4.249 7.971 3.993 C 7.714 3.736 7.52 3.424 7.405 3.079 L 6.953 1.691 C 6.881 1.489 6.748 1.314 6.571 1.191 C 6.439 1.098 6.286 1.036 6.125 1.012 C 5.965 0.987 5.801 1.001 5.646 1.051 C 5.492 1.101 5.351 1.187 5.236 1.301 C 5.12 1.415 5.033 1.555 4.98 1.708 L 4.523 3.108 C 4.409 3.443 4.22 3.748 3.97 3.999 C 3.721 4.25 3.418 4.441 3.083 4.557 L 1.692 5.005 C 1.541 5.06 1.404 5.149 1.292 5.265 C 1.18 5.381 1.097 5.521 1.048 5.675 C 1 5.829 0.988 5.992 1.013 6.151 C 1.038 6.31 1.099 6.462 1.192 6.593 C 1.32 6.773 1.501 6.908 1.709 6.979 L 3.083 7.424 C 3.524 7.571 3.91 7.845 4.193 8.212 C 4.356 8.423 4.481 8.66 4.564 8.912 L 5.016 10.303 C 5.088 10.507 5.222 10.683 5.398 10.807 Z M 11.535 14.849 C 11.671 14.946 11.834 14.997 12 14.997 C 12.165 14.997 12.326 14.946 12.461 14.851 C 12.601 14.753 12.706 14.613 12.761 14.451 L 13.009 13.689 C 13.063 13.531 13.152 13.387 13.269 13.268 C 13.387 13.15 13.531 13.061 13.689 13.009 L 14.461 12.757 C 14.619 12.703 14.756 12.6 14.852 12.464 C 14.926 12.361 14.974 12.242 14.992 12.117 C 15.011 11.992 14.999 11.865 14.959 11.745 C 14.918 11.625 14.85 11.516 14.76 11.428 C 14.669 11.34 14.559 11.274 14.438 11.236 L 13.674 10.987 C 13.516 10.935 13.372 10.846 13.254 10.729 C 13.136 10.611 13.047 10.467 12.994 10.309 L 12.742 9.536 C 12.689 9.379 12.586 9.242 12.449 9.146 C 12.347 9.073 12.23 9.025 12.106 9.006 C 11.982 8.987 11.855 8.998 11.736 9.037 C 11.616 9.076 11.508 9.142 11.419 9.231 C 11.33 9.319 11.264 9.427 11.224 9.546 L 10.977 10.308 C 10.925 10.466 10.838 10.61 10.721 10.728 C 10.607 10.845 10.467 10.934 10.312 10.987 L 9.539 11.239 C 9.38 11.293 9.242 11.396 9.145 11.533 C 9.047 11.669 8.995 11.833 8.996 12.001 C 8.997 12.169 9.051 12.333 9.15 12.468 C 9.249 12.604 9.388 12.705 9.547 12.757 L 10.31 13.004 C 10.469 13.058 10.614 13.147 10.732 13.265 C 10.851 13.384 10.939 13.528 10.99 13.687 L 11.243 14.461 C 11.298 14.618 11.4 14.753 11.535 14.849 Z" />
                                </svg>
                            </button>
                            <hr>
                            <%}%>
                                <% if(pageData.type=="text" || pageData.type=="image" || pageData.type=="choice" ) {%>
                                    <button type="button" class="btn btn-secondary newElement" data-bs-toggle="modal"
                                        data-bs-request="POST" data-bs-elementtype="condition"
                                        data-bs-elementuuid="<%=pageData.uuid %>" data-bs-elementvalue=""
                                        data-bs-target="#conditionUpdateModal">+
                                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16"
                                            fill="currentColor" class="bi bi-question-diamond" viewBox="0 0 16 16">
                                            <path
                                                d="M6.95.435c.58-.58 1.52-.58 2.1 0l6.515 6.516c.58.58.58 1.519 0 2.098L9.05 15.565c-.58.58-1.519.58-2.098 0L.435 9.05a1.48 1.48 0 0 1 0-2.098zm1.4.7a.495.495 0 0 0-.7 0L1.134 7.65a.495.495 0 0 0 0 .7l6.516 6.516a.495.495 0 0 0 .7 0l6.516-6.516a.495.495 0 0 0 0-.7L8.35 1.134z" />
                                            <path
                                                d="M5.255 5.786a.237.237 0 0 0 .241.247h.825c.138 0 .248-.113.266-.25.09-.656.54-1.134 1.342-1.134.686 0 1.314.343 1.314 1.168 0 .635-.374.927-.965 1.371-.673.489-1.206 1.06-1.168 1.987l.003.217a.25.25 0 0 0 .25.246h.811a.25.25 0 0 0 .25-.25v-.105c0-.718.273-.927 1.01-1.486.609-.463 1.244-.977 1.244-2.056 0-1.511-1.276-2.241-2.673-2.241-1.267 0-2.655.59-2.75 2.286m1.557 5.763c0 .533.425.927 1.01.927.609 0 1.028-.394 1.028-.927 0-.552-.42-.94-1.029-.94-.584 0-1.009.388-1.009.94" />
                                        </svg>
                                    </button>
                                    <%}%>

                                        <div class="feedback-status">
                                            <% if(locals.errors){%>
                                                <div class="alert alert-danger">
                                                    <ul>
                                                        <% errors.forEach(function (error){%>
                                                            <li>
                                                                <%= error.msg %>
                                                            </li>
                                                            <%})%>
                                                    </ul>
                                                </div>
                                                <%}else if(locals.successMessage) {%>
                                                    <div class="alert alert-success">
                                                        <%= successMessage %>
                                                    </div>
                                                    <%}%>
                                        </div>
            </div>
        </div>
        <aside class="col-md-8">
            <div class="maincontent feedback">
                <h1>
                    <% if(pageData.type=="story" || pageData.type=="page" ){ %>
                        <%= pageData.value %>
                            <%}else{%>
                                Editing <%= pageData.type %>
                                    <%}%>
                </h1>

                <div id="draggableList" class="list-group feedback-items">
                    <% pageListItems.forEach(function (item) {%>
                        <%- include(`partials/${listPartialToUse}`, {item: item, allPageUUIDs: allPageUUIDs}); %>
                            <%})%>

                </div>
            </div>
        </aside>
    </div>
    <div class="modal fade elementModal" id="textUpdateModal" tabindex="-1" aria-labelledby="textUpdateLabel"
        aria-hidden="true">
        <div class="modal-dialog modal-lg">
            <%- include('partials/formElementTextModal', {uuid:pageData.uuid}); %>
        </div>
    </div>
    <div class="modal fade elementModal" id="imageUpdateModal" tabindex="-1" aria-labelledby="elementUpdateLabel"
        aria-hidden="true">
        <div class="modal-dialog modal-lg">
            <%- include('partials/formElementImageModal', {uuid:pageData.uuid}); %>
        </div>
    </div>
    <div class="modal fade elementAiModal" id="aiimageUpdateModal" tabindex="-1" aria-labelledby="elementUpdateLabel"
        aria-hidden="true">
        <div class="modal-dialog modal-lg">
            <%- include('partials/formElementImageModal_AI', {uuid:pageData.uuid}); %>
        </div>
    </div>
    <div class="modal fade elementModal" id="choiceUpdateModal" tabindex="-1" aria-labelledby="textUpdateLabel"
        aria-hidden="true">
        <div class="modal-dialog modal-lg">
            <%- include('partials/formElementChoiceModal', {uuid:pageData.uuid}); %>
        </div>
    </div>
    <div class="modal fade elementModal" id="conditionUpdateModal" tabindex="-1" aria-labelledby="textUpdateLabel"
        aria-hidden="true">
        <div class="modal-dialog modal-lg">
            <%- include('partials/formElementConditionModal', {uuid:pageData.uuid}); %>
        </div>
    </div>
    <div class="modal fade elementModal" id="pageUpdateModal" tabindex="-1" aria-labelledby="pageUpdateLabel"
        aria-hidden="true">
        <div class="modal-dialog modal-lg">
            <%- include('partials/formPageModal', {uuid:pageData.uuid}); %>
        </div>
    </div>
    <%- include('partials/deletePageModal', {}); %>
        <div aria-live="polite" aria-atomic="true" class="d-flex justify-content-center align-items-center"
            style="min-height: 200px;">
            <!-- Position it -->
            <div style="position: fixed; top: 0; right: 0;">

                <!-- Then put toasts within -->
                <div id="myTextToast" class="toast successToast" role="alert" aria-live="assertive"
                    data-autohide="false" aria-atomic="true">
                    <div class="toast-header successToast">
                        <!-- <img src="..." class="rounded mr-2" alt="..."> -->
                        <strong class="mr-auto">Success</strong>
                        <small class="text-muted">just now</small>
                        <button type="button" class="ml-2 mb-1 close" data-dismiss="toast" aria-label="Close">
                            <span aria-hidden="true">&times;</span>
                        </button>
                    </div>
                    <div class="toast-body">
                        New Text Element Created!
                    </div>
                </div>

                <div id="myImageToast" class="toast successToast" role="alert" aria-live="assertive"
                    data-autohide="false" aria-atomic="true">
                    <div class="toast-header successToast">
                        <!-- <img src="..." class="rounded mr-2" alt="..."> -->
                        <strong class="mr-auto">Success</strong>
                        <small class="text-muted">2 seconds ago</small>
                        <button type="button" class="ml-2 mb-1 close" data-dismiss="toast" aria-label="Close">
                            <span aria-hidden="true">&times;</span>
                        </button>
                    </div>
                    <div class="toast-body">
                        New Image Element Created!
                    </div>
                </div>

                <div id="myChoiceToast" class="toast successToast" role="alert" aria-live="assertive"
                    data-autohide="false" aria-atomic="true">
                    <div class="toast-header successToast">
                        <!-- <img src="..." class="rounded mr-2" alt="..."> -->
                        <strong class="mr-auto">Success</strong>
                        <small class="text-muted">2 seconds ago</small>
                        <button type="button" class="ml-2 mb-1 close" data-dismiss="toast" aria-label="Close">
                            <span aria-hidden="true">&times;</span>
                        </button>
                    </div>
                    <div class="toast-body">
                        New Choice Element Created!
                    </div>
                </div>

                <div id="myConditionToast" class="toast successToast" role="alert" aria-live="assertive"
                    data-autohide="false" aria-atomic="true">
                    <div class="toast-header successToast">
                        <!-- <img src="..." class="rounded mr-2" alt="..."> -->
                        <strong class="mr-auto">Success</strong>
                        <small class="text-muted">2 seconds ago</small>
                        <button type="button" class="ml-2 mb-1 close" data-dismiss="toast" aria-label="Close">
                            <span aria-hidden="true">&times;</span>
                        </button>
                    </div>
                    <div class="toast-body">
                        New Condition Created!
                    </div>
                </div>

                <div id="myPageToast" class="toast successToast" role="alert" aria-live="assertive"
                    data-autohide="false" aria-atomic="true">
                    <div class="toast-header successToast">
                        <!-- <img src="..." class="rounded mr-2" alt="..."> -->
                        <strong class="mr-auto">Success</strong>
                        <small class="text-muted">2 seconds ago</small>
                        <button type="button" class="ml-2 mb-1 close" data-dismiss="toast" aria-label="Close">
                            <span aria-hidden="true">&times;</span>
                        </button>
                    </div>
                    <div class="toast-body">
                        New Page Created!
                    </div>
                </div>
            </div>
        </div>




</div>