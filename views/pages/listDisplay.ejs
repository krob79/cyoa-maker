<div id="container" class="container mt-4">
    <div class="row">
        <div class="col-md-3">
            <div class="maincontent">
                <!-- If the data type you're currently viewing is of type "story", then the list should show story elements that have a type of "page". The "New Page" button should be visible to create more "pages" within the same story  -->
                <% if(pageData.type=="story" ) {%>
                    <button type="button" class="btn btn-secondary newElement" data-bs-toggle="modal"
                        data-bs-request="POST" data-bs-elementtype="page" data-bs-elementuuid="<%=story.uuid %>"
                        data-bs-elementvalue="" data-bs-target="#pageUpdateModal">+<svg
                            xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor"
                            class="bi bi-file-earmark" viewBox="0 0 16 16">
                            <path
                                d="M14 4.5V14a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V2a2 2 0 0 1 2-2h5.5zm-3 0A1.5 1.5 0 0 1 9.5 3V1H4a1 1 0 0 0-1 1v12a1 1 0 0 0 1 1h8a1 1 0 0 0 1-1V4.5z" />
                        </svg></button>
                    <%}%>
                        <!-- If the data type you're currently viewing is of type "page", then the list should show page elements that have a type of "text", "image", or "choice". The "New Text/Image/Choice" buttons should be visible to create more of these within the same page  -->
                        <% if(pageData.type=="page" ) {%>
                            <button type="button" class="btn btn-secondary newElement" data-bs-toggle="modal"
                                data-bs-request="POST" data-bs-elementtype="text"
                                data-bs-elementuuid="<%=pageData.uuid %>" data-bs-elementvalue=""
                                data-bs-target="#textUpdateModal">+
                                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor"
                                    class="bi bi-type" viewBox="0 0 16 16">
                                    <path
                                        d="m2.244 13.081.943-2.803H6.66l.944 2.803H8.86L5.54 3.75H4.322L1 13.081zm2.7-7.923L6.34 9.314H3.51l1.4-4.156zm9.146 7.027h.035v.896h1.128V8.125c0-1.51-1.114-2.345-2.646-2.345-1.736 0-2.59.916-2.666 2.174h1.108c.068-.718.595-1.19 1.517-1.19.971 0 1.518.52 1.518 1.464v.731H12.19c-1.647.007-2.522.8-2.522 2.058 0 1.319.957 2.18 2.345 2.18 1.06 0 1.716-.43 2.078-1.011zm-1.763.035c-.752 0-1.456-.397-1.456-1.244 0-.65.424-1.115 1.408-1.115h1.805v.834c0 .896-.752 1.525-1.757 1.525" />
                                </svg>
                            </button>
                            <button type="button" class="btn btn-secondary newElement" data-bs-toggle="modal"
                                data-bs-request="POST" data-bs-elementtype="image"
                                data-bs-elementuuid="<%=pageData.uuid %>" data-bs-elementvalue=""
                                data-bs-target="#imageUpdateModal">+<svg xmlns="http://www.w3.org/2000/svg" width="16"
                                    height="16" fill="currentColor" class="bi bi-image" viewBox="0 0 16 16">
                                    <path d="M6.002 5.5a1.5 1.5 0 1 1-3 0 1.5 1.5 0 0 1 3 0" />
                                    <path
                                        d="M2.002 1a2 2 0 0 0-2 2v10a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V3a2 2 0 0 0-2-2zm12 1a1 1 0 0 1 1 1v6.5l-3.777-1.947a.5.5 0 0 0-.577.093l-3.71 3.71-2.66-1.772a.5.5 0 0 0-.63.062L1.002 12V3a1 1 0 0 1 1-1z" />
                                </svg>
                            </button>
                            <button type="button" class="btn btn-secondary newElement" data-bs-toggle="modal"
                                data-bs-request="POST" data-bs-elementtype="choice" data-bs-storyuuid="<%=story.uuid%>"
                                data-bs-elementuuid="<%=pageData.uuid %>" data-bs-elementvalue=""
                                data-bs-target="#choiceUpdateModal">+<svg xmlns="http://www.w3.org/2000/svg" width="16"
                                    height="16" fill="currentColor" class="bi bi-link-45deg" viewBox="0 0 16 16">
                                    <path
                                        d="M4.715 6.542 3.343 7.914a3 3 0 1 0 4.243 4.243l1.828-1.829A3 3 0 0 0 8.586 5.5L8 6.086a1 1 0 0 0-.154.199 2 2 0 0 1 .861 3.337L6.88 11.45a2 2 0 1 1-2.83-2.83l.793-.792a4 4 0 0 1-.128-1.287z" />
                                    <path
                                        d="M6.586 4.672A3 3 0 0 0 7.414 9.5l.775-.776a2 2 0 0 1-.896-3.346L9.12 3.55a2 2 0 1 1 2.83 2.83l-.793.792c.112.42.155.855.128 1.287l1.372-1.372a3 3 0 1 0-4.243-4.243z" />
                                </svg></button>
                            <button type="button" class="btn btn-secondary newElement" data-bs-toggle="modal"
                                data-bs-request="POST" data-bs-elementtype="event" data-bs-storyuuid="<%=story.uuid%>"
                                data-bs-elementuuid="<%=pageData.uuid %>" data-bs-elementvalue=""
                                data-bs-target="#eventUpdateModal">+<svg xmlns="http://www.w3.org/2000/svg" width="24"
                                    height="24" fill="currentColor" viewBox="0 -960 960 960">
                                    <path
                                        d="M480-280q17 0 28.5-11.5T520-320t-11.5-28.5T480-360t-28.5 11.5T440-320t11.5 28.5T480-280m-40-160h80v-240h-80zm40 412L346-160H160v-186L28-480l132-134v-186h186l134-132 134 132h186v186l132 134-132 134v186H614zm0-112 100-100h140v-140l100-100-100-100v-140H580L480-820 380-720H240v140L140-480l100 100v140h140zm0-340" />
                                </svg></button>

                            <%}%>
                                <!-- If the data type you're currently viewing is of type "text", "image", or "choice", then the list should show elements from one text/image/choice element that have a type of "condition". The "New Condition" button should be visible to create more of these conditions for a single text/image/choice element  -->
                                <% if(pageData.type=="text" || pageData.type=="image" || pageData.type=="choice" ||
                                    pageData.type=="event" ) {%>
                                    <button type="button" class="btn btn-secondary newElement" data-bs-toggle="modal"
                                        data-bs-request="POST" data-bs-elementtype="condition"
                                        data-bs-elementuuid="<%=pageData.uuid %>" data-bs-elementvalue=""
                                        data-bs-target="#conditionUpdateModal">+
                                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16"
                                            fill="currentColor" class="bi bi-question-diamond" viewBox="0 0 16 16">
                                            <path
                                                d="M6.95.435c.58-.58 1.52-.58 2.1 0l6.515 6.516c.58.58.58 1.519 0 2.098L9.05 15.565c-.58.58-1.519.58-2.098 0L.435 9.05a1.48 1.48 0 0 1 0-2.098zm1.4.7a.495.495 0 0 0-.7 0L1.134 7.65a.495.495 0 0 0 0 .7l6.516 6.516a.495.495 0 0 0 .7 0l6.516-6.516a.495.495 0 0 0 0-.7L8.35 1.134z" />
                                            <path
                                                d="M5.255 5.786a.237.237 0 0 0 .241.247h.825c.138 0 .248-.113.266-.25.09-.656.54-1.134 1.342-1.134.686 0 1.314.343 1.314 1.168 0 .635-.374.927-.965 1.371-.673.489-1.206 1.06-1.168 1.987l.003.217a.25.25 0 0 0 .25.246h.811a.25.25 0 0 0 .25-.25v-.105c0-.718.273-.927 1.01-1.486.609-.463 1.244-.977 1.244-2.056 0-1.511-1.276-2.241-2.673-2.241-1.267 0-2.655.59-2.75 2.286m1.557 5.763c0 .533.425.927 1.01.927.609 0 1.028-.394 1.028-.927 0-.552-.42-.94-1.029-.94-.584 0-1.009.388-1.009.94" />
                                        </svg>
                                    </button>
                                    <% if(pageData.type=="choice" ){%>
                                        <button type="button" class="btn btn-secondary newElement"
                                            data-bs-toggle="modal" data-bs-request="POST" data-bs-elementtype="event"
                                            data-bs-storyuuid="<%=story.uuid%>"
                                            data-bs-elementuuid="<%=pageData.uuid %>" data-bs-elementvalue=""
                                            data-bs-target="#eventUpdateModal">+<svg xmlns="http://www.w3.org/2000/svg"
                                                width="24" height="24" fill="currentColor" viewBox="0 -960 960 960">
                                                <path
                                                    d="M480-280q17 0 28.5-11.5T520-320t-11.5-28.5T480-360t-28.5 11.5T440-320t11.5 28.5T480-280m-40-160h80v-240h-80zm40 412L346-160H160v-186L28-480l132-134v-186h186l134-132 134 132h186v186l132 134-132 134v186H614zm0-112 100-100h140v-140l100-100-100-100v-140H580L480-820 380-720H240v140L140-480l100 100v140h140zm0-340" />
                                            </svg></button>
                                        <%}%>

                                            <%}%>
                                                <hr>
                                                <a href="/page/<%=pageData.uuid%>/view/">View Page</a><br />
                                                <a href="/page/<%=pageData.uuid%>/graph/">Graph</a><br />
                                                <a href="/page/<%=pageData.uuid%>/allevents/">Event List</a><br />
                                                <hr>
                                                <% if(query){%>
                                                    <a href="/page/<%=pageData.parent%>/edit?q=<%=pageData.uuid%>">&lt;
                                                        View Parent</a>
                                                    <%}else{%>
                                                        <a href="/page/<%=pageData.parent%>/edit">&lt;
                                                            View Parent</a>
                                                        <%}%>
                                                            <div class="feedback-status">
                                                                <% if(locals.errors){%>
                                                                    <div class="alert alert-danger">
                                                                        <ul>
                                                                            <% errors.forEach(function (error){%>
                                                                                <li>
                                                                                    <%= error.msg %>
                                                                                </li>
                                                                                <%})%>
                                                                        </ul>
                                                                    </div>
                                                                    <%}else if(locals.successMessage) {%>
                                                                        <div class="alert alert-success">
                                                                            <%= successMessage %>
                                                                        </div>
                                                                        <%}%>
                                                            </div>

            </div>
        </div>
        <aside class="col-md-9">
            <div class="maincontent feedback">
                <h1>
                    <% if(pageData.type=="story" || pageData.type=="page" ){ %>
                        <%= pageData.value %>
                            <%}else if(pageData.type=="text" || pageData.type=="image" || pageData.type=="choice" ){%>
                                Editing Condition of <%= pageData.type %> element
                                    <%}else{%>
                                        Editing <%= pageData.type %>
                                            <%}%>
                </h1>
                <div id="eventList">
                    <% events.forEach((evt)=>{%>
                        <div class="feedback-item">
                            <p>Event Found: <%= evt.value %>
                            </p>
                        </div>
                        <%})%>

                </div>
                <div id="draggableList" class="list-group feedback-items">
                    <%if(pageListItems.length> 0){%>
                        <% pageListItems.forEach(function (item) {%>

                            <%- include(`partials/entry`, {item: item, allPageUUIDs: allPageUUIDs});%>

                                <%})%>
                                    <%} else {%>
                                        <p><strong>No items yet listed</strong></p>
                                        <p><a href="javascript:history.go(-1)">&lt; Go Back</a></p>
                                        <%}%>
                </div>
            </div>
        </aside>
    </div>
    <%- include('partials/modals', {pageData:pageData}); %>
        <%- include('partials/toasts', {}); %>

</div>